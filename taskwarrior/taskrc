
regex=on

data.location=/home/jeyzu/usr/data/task/

include /usr/share/doc/task/rc/dark-yellow-green.theme
#include /usr/share/doc/task/rc/dark-green-256.theme

active.indicator=>
default.project=Inbox

uda.taskwarrior-tui.keyconfig.up=s
uda.taskwarrior-tui.keyconfig.down=t
uda.taskwarrior-tui.keyconfig.page-up=S
uda.taskwarrior-tui.keyconfig.page-down=T
uda.taskwarrior-tui.keyconfig.start-stop=;
uda.taskwarrior-tui.keyconfig.quick-tag=^

color=on
dateformat=D.M
dateformat.annotation=D.M
dateformat.report=D.M
weekstart=monday

# State : active / blocked / waiting / review
uda.state.type=string
uda.state.label=State
uda.state.values=active,blocked,waiting,review
color.uda.state.blocked=bold white on red

# Note
uda.note.type=string
uda.note.label=Note

# Priority : H / M / L
uda.priority.type=string
uda.priority.label=Priority
uda.priority.values=H,M,L,
color.uda.priority.H=color255
color.uda.priority.L=color245
color.uda.priority.M=color250
urgency.uda.priority.H.coefficient=6.0
urgency.uda.priority.L.coefficient=1.8
urgency.uda.priority.M.coefficient=3.9

# Effort : s / m / l / xl / xxl
uda.effort.type=string
uda.effort.label=Effort
uda.effort.values=s,m,l,xl,xxl
urgency.uda.effort.s.coefficient=1.5
urgency.uda.effort.m.coefficient=1.1
urgency.uda.effort.l.coefficient=1
urgency.uda.effort.xl.coefficient=0
urgency.uda.effort.xxl.coefficient=-0.2
color.uda.effort.s=color180
color.uda.effort.m=color210
color.uda.effort.l=color255
color.uda.effort.xl=color255
color.uda.effort.xxl=color255

# Completion
uda.completion.type=numeric
uda.completion.label=Completion
uda.completion.default=0

# Project color
color.project.admin=green

# Report now
news.version=3.4.2
report.now.description=10 following tasks
report.now.labels=ID,Active,Age,Deps,P,Effort,Project,Tag,Recur,S,Due,Until,Description,Urg
report.now.columns=id,start.age,entry.age,depends,priority,effort,project,tags,recur,scheduled.countdown,due.relative,until.remaining,description,urgency
report.now.filter=status:pending limit:30 -hide
report.now.sort=due+,priority-

context.hmsa.read=+hmsa
context.hmsa.write=+hmsa
context.asynk.read=+asynk
context.asynk.write=+asynk
context.home.read=+home
context.home.write=+home
